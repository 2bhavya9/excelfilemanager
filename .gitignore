# ─────────────────────────────────────────────────────────────
#  .gitignore — Excel File Manager (frontend / Electron)
# ─────────────────────────────────────────────────────────────


# ── OS ────────────────────────────────────────────────────────
.DS_Store
._*
Thumbs.db
desktop.ini


# ── Editor ────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~


# ── Node / npm ────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm


# ── Vite ──────────────────────────────────────────────────────
dist/
dist-ssr/
*.local
.vite/


# ── Electron build output ─────────────────────────────────────
release/
out/
.cache/
electron-builder-cache/


# ── Logs ──────────────────────────────────────────────────────
logs/
*.log


# ── Secrets ───────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

